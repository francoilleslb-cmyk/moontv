<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#10131A"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="MoonTV - Smart TV"
        android:textColor="#FFFFFF"
        android:textSize="28sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnLiveTv"
            style="@style/Widget.MoonTV.SectionButton"
            android:text="TV en vivo" />

        <Button
            android:id="@+id/btnMovies"
            style="@style/Widget.MoonTV.SectionButton"
            android:text="Películas" />

        <Button
            android:id="@+id/btnSeries"
            style="@style/Widget.MoonTV.SectionButton"
            android:text="Series" />

        <Button
            android:id="@+id/btnEvents"
            style="@style/Widget.MoonTV.SectionButton"
            android:text="Eventos" />
    </LinearLayout>

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="16dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/mediaRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_weight="1" />

</LinearLayout>
